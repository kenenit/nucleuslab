# next-auth@5 (beta) declares a peerDependencies range of "^14.0.0-0 || ^15.0.0-0"
# for next, which doesn't yet list Next.js 16 — even though Auth.js v5 and
# Next.js 16 are confirmed compatible in practice; the published metadata just
# hasn't caught up. Without this, `npm install` fails with ERESOLVE, including
# in Vercel's build environment. Remove this once next-auth publishes a
# version with an updated peer range for Next 16.
legacy-peer-deps=true
