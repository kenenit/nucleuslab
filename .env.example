# Database (PostgreSQL) — e.g. Neon, Supabase, Railway, or a local instance
DATABASE_URL="postgresql://user:password@localhost:5432/nucleus_labs?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (for contact form notifications / newsletter — plug in Resend, Postmark, SES, etc.)
EMAIL_FROM="hello@nucleuslabs.com"
EMAIL_PROVIDER_API_KEY=""

# File uploads (e.g. S3-compatible bucket — Cloudflare R2, AWS S3, Supabase Storage)
UPLOADS_BUCKET_NAME=""
UPLOADS_ACCESS_KEY_ID=""
UPLOADS_SECRET_ACCESS_KEY=""
UPLOADS_REGION=""

# Rate limiting (optional — e.g. Upstash Redis for production-grade limits)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
