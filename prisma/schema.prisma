// Nucleus Labs — Database schema
// Run `npx prisma db push` (prototyping) or `npx prisma migrate dev` (tracked migrations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH (NextAuth — Credentials provider, admin dashboard only)
// ============================================================

enum Role {
  ADMIN
  EDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String
  role          Role      @default(EDITOR)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================================
// CONTENT: SERVICES
// ============================================================

model Service {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  summary      String
  description  String   @db.Text
  benefits     String[] // short bullet points
  process      String[] // ordered mini-process labels
  technologies String[]
  icon         String? // icon key rendered via lucide-react on the frontend
  order        Int      @default(0)
  published    Boolean  @default(true)
  seo          Json? // { title, description, ogImage }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// CONTENT: PRODUCTS
// ============================================================

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  tagline       String
  overview      String   @db.Text
  features      String[]
  screenshots   String[] // uploaded image URLs
  storeUrlIos   String?
  storeUrlAndroid String?
  liveDemoUrl   String?
  learnMoreUrl  String?
  socialLinks   Json? // { instagram, linkedin, twitter, ... }
  order         Int      @default(0)
  published     Boolean  @default(true)
  seo           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// CONTENT: PORTFOLIO / PROJECTS (case studies)
// ============================================================

model Project {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  client          String?
  category        String // e.g. "Web", "Mobile", "AI"
  summary         String
  problem         String?  @db.Text
  solution        String?  @db.Text
  results         String?  @db.Text
  technologies    String[]
  coverImage      String?
  gallery         String[]
  beforeImage     String?
  afterImage      String?
  featured        Boolean  @default(false)
  order           Int      @default(0)
  published       Boolean  @default(true)
  seo             Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// CONTENT: TESTIMONIALS
// ============================================================

model Testimonial {
  id         String   @id @default(cuid())
  quote      String   @db.Text
  authorName String
  authorRole String?
  company    String?
  avatarUrl  String?
  rating     Int      @default(5)
  featured   Boolean  @default(false)
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================================
// CONTENT: TEAM
// ============================================================

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String?  @db.Text
  photoUrl    String?
  linkedinUrl String?
  isLeadership Boolean @default(false)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// CONTENT: BLOG / INSIGHTS
// ============================================================

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text // markdown or rich-text JSON, renderer's choice
  coverImage  String?
  category    String // AI, Technology, Automation, Software, Business, Innovation
  tags        String[]
  authorId    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  seo         Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// CONTENT: CAREERS
// ============================================================

model JobListing {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  department    String?
  type          String // Full-time, Internship, Contract
  location      String // Remote, Addis Ababa, etc.
  description   String   @db.Text
  requirements  String[]
  isInternship  Boolean  @default(false)
  published     Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  applications  JobApplication[]
}

model JobApplication {
  id           String     @id @default(cuid())
  jobListingId String?
  jobListing   JobListing? @relation(fields: [jobListingId], references: [id], onDelete: SetNull)
  fullName     String
  email        String
  phone        String?
  coverLetter  String?    @db.Text
  resumeUrl    String
  status       ApplicationStatus @default(NEW)
  createdAt    DateTime   @default(now())
}

enum ApplicationStatus {
  NEW
  REVIEWING
  INTERVIEWING
  REJECTED
  HIRED
}

// ============================================================
// FORMS: CONTACT + NEWSLETTER
// ============================================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String? // which service they're interested in, optional
  message   String   @db.Text
  status    ContactStatus @default(NEW)
  source    String? // which page/CTA it came from
  createdAt DateTime @default(now())
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  subscribed  Boolean  @default(true)
  createdAt   DateTime @default(now())
  unsubscribedAt DateTime?
}

// ============================================================
// SITE-WIDE SEO SETTINGS
// ============================================================

model SeoSetting {
  id              String @id @default(cuid())
  pageKey         String @unique // "home", "about", "services", etc.
  title           String
  description     String
  ogImage         String?
  canonicalUrl    String?
  structuredData  Json?
  updatedAt       DateTime @updatedAt
}

// ============================================================
// INDUSTRIES (simple reference content for the "Industries We Serve" page)
// ============================================================

model Industry {
  id        String  @id @default(cuid())
  name      String  @unique
  icon      String?
  order     Int     @default(0)
  published Boolean @default(true)
}
